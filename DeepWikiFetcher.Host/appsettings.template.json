{
  "Crawler": {
    "MaxConcurrency": 3,
    "RequestIntervalSeconds": 2,
    "RateLimitPerMinute": 30,
    "TimeoutSeconds": 30,
    "RetryMaxAttempts": 3,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerDurationSeconds": 30,
    "UserAgent": "DeepWikiFetcher/1.0",
    "OutputRoot": "./Output",
    "OutputFormat": "markdown",
    "CacheEnabled": true,
    "CacheExpirationHours": 24
  },
  "Playwright": {
    "Enabled": false,
    "BrowserType": "chromium",
    "PageLoadTimeoutSeconds": 60
  },
  "Translation": {
    "Enabled": false,
    "BaseUrl": "https://api.openai.com/v1",
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "TargetLanguage": "zh-cn",
    "BatchSize": 10,
    "MaxTokensPerRequest": 4096,
    "Temperature": 0.1,
    "RequestDelayMs": 500
  }
}
